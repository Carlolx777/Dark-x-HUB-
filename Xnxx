local flingBoatLoop = false -- Variável para controlar o loop

TabTroll:AddToggle({
    Name = "Fling Boat",
    Default = false,
    Callback = function(Value)
        flingBoatLoop = Value
        
        local Player = game.Players.LocalPlayer
        local Character = Player.Character
        local Humanoid = Character and Character:FindFirstChildOfClass("Humanoid")
        local RootPart = Character and Character:FindFirstChild("HumanoidRootPart")
        local Vehicles = game.Workspace:FindFirstChild("Vehicles")

        if Value then
            -- ================= LÓGICA DE LIGAR =================
            local selectedPlayerName = _G.SelectedPlayer
            if not selectedPlayerName or not game.Players:FindFirstChild(selectedPlayerName) then
                warn("Nenhum jogador selecionado ou não existe")
                return
            end

            if not Humanoid or not RootPart then
                warn("Humanoid ou RootPart inválido")
                return
            end

            local function spawnBoat()
                RootPart.CFrame = CFrame.new(1754, -2, 58)
                task.wait(0.5)
                game:GetService("ReplicatedStorage").RE:FindFirstChild("1Ca1r"):FireServer("PickingBoat", "MilitaryBoatFree")
                task.wait(1)
                return Vehicles:FindFirstChild(Player.Name.."Car")
            end

            local PCar = Vehicles:FindFirstChild(Player.Name.."Car") or spawnBoat()
            if not PCar then 
                warn("Falha ao spawnar o barco")
                return
            end

            local Seat = PCar:FindFirstChild("Body") and PCar.Body:FindFirstChild("VehicleSeat")
            if not Seat then
                warn("Assento não encontrado")
                return
            end

            -- Entrar no barco
            repeat 
                task.wait(0.1)
                RootPart.CFrame = Seat.CFrame * CFrame.new(0, 1, 0)
            until Humanoid.SeatPart == Seat or not flingBoatLoop

            print("Barco pronto e ocupado!")

            local TargetPlayer = game.Players:FindFirstChild(selectedPlayerName)
            if not TargetPlayer or not TargetPlayer.Character then return end
            
            local TargetC = TargetPlayer.Character
            local TargetRP = TargetC:FindFirstChild("HumanoidRootPart")

            -- Configurar o Spin
            local Spin = Instance.new("BodyAngularVelocity")
            Spin.Name = "SpinningBoat"
            Spin.Parent = PCar.PrimaryPart
            Spin.MaxTorque = Vector3.new(0, math.huge, 0)
            Spin.AngularVelocity = Vector3.new(0, 369, 0) 

            print("Fling Boat Ativo!")

            -- Loop de Movimento
            task.spawn(function()
                while flingBoatLoop and PCar and PCar.Parent and TargetRP and TargetRP.Parent do
                    task.wait(0.01) 
                    
                    local function move(offset)
                        if PCar and PCar.PrimaryPart then
                            PCar:SetPrimaryPartCFrame(CFrame.new(TargetRP.Position + offset))
                        end
                    end

                    move(Vector3.new(0, 1, 0)) 
                    move(Vector3.new(0, -2.25, 5)) 
                    move(Vector3.new(0, 2.25, 0.25)) 
                    move(Vector3.new(-2.25, -1.5, 2.25)) 
                    
                    if PCar and PCar.PrimaryPart then 
                        local Rotation = CFrame.Angles(
                            math.rad(math.random(-369, 369)), 
                            math.rad(math.random(-369, 369)), 
                            math.rad(math.random(-369, 369))
                        )
                        PCar:SetPrimaryPartCFrame(CFrame.new(TargetRP.Position + Vector3.new(0, 1.5, 0)) * Rotation)
                    end
                end
                
                -- Limpeza automática se o loop quebrar ou o barco sumir
                if Spin then Spin:Destroy() end
            end)

        else
            -- ================= LÓGICA DE DESLIGAR =================
            flingBoatLoop = false
            print("Desativando Fling Boat...")

            if not RootPart or not Humanoid then return end

            Humanoid.PlatformStand = true
            
            -- Limpar forças do jogador
            for _, obj in pairs(RootPart:GetChildren()) do
                if obj:IsA("BodyAngularVelocity") or obj:IsA("BodyVelocity") then
                    obj:Destroy()
                end
            end

            -- Deletar barco
            game:GetService("ReplicatedStorage").RE:FindFirstChild("1Ca1r"):FireServer("DeleteAllVehicles")
            
