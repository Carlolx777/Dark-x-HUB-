local function ForcePart(v)
    if v:IsA("BasePart") and not v.Anchored and not v.Parent:FindFirstChildOfClass("Humanoid") and v.Name ~= "Handle" then
        for _, x in ipairs(v:GetChildren()) do
            if x:IsA("BodyMover") or x:IsA("AlignPosition") or x:IsA("Torque") then x:Destroy() end
        end
        v.CanCollide = false
        local torque = Instance.new("Torque", v)
        torque.Torque = Vector3.new(100000000, 1000000000, 100000000)
        local att0 = Instance.new("Attachment", v)
        torque.Attachment0 = att0
        local alignPos = Instance.new("AlignPosition", v)
        alignPos.Name = "BH_Force"
        alignPos.MaxForce = math.huge
        alignPos.MaxVelocity = math.huge
        alignPos.Responsiveness = _G.BH_Strength
        alignPos.Attachment0 = att0
        alignPos.Attachment1 = BH_Attachment
    end
end

local function PulseLoop(targetPlayer, actionCallback)
    _G.IsTrapping = true
    local PosOriginal = vu7.Character.HumanoidRootPart.CFrame
    vu8.RE["1Too1l"]:InvokeServer("PickingTools", "Couch")
    
    local connection
    connection = vu10.Heartbeat:Connect(function()
        if not _G.IsTrapping or not targetPlayer.Character then 
            connection:Disconnect() 
            return 
        end
        
        local THRP = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        local THum = targetPlayer.Character:FindFirstChild("Humanoid")
        
        if THRP and THum then
            local Tool = vu7.Backpack:FindFirstChild("Couch") or vu7.Character:FindFirstChild("Couch")
            if Tool then vu7.Character.Humanoid:EquipTool(Tool) end
            
            local timer = tick() * 14 
            local dist = math.sin(timer) * 8 -- Movimento de entra e sai
            
            vu7.Character.HumanoidRootPart.CFrame = THRP.CFrame * CFrame.new(0, 0.5, dist) * CFrame.Angles(0, timer, 0)
            vu7.Character.HumanoidRootPart.Velocity = Vector3.new(0,0,0)
            
            if THum.Sit then
                connection:Disconnect()
                actionCallback(PosOriginal)
            end
        end
    end)
end

