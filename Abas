TabTP:AddButton({
    Name = "Servidor com Poucas Pessoas (Server Hop)",
    Callback = function()
        local PlaceID = game.PlaceId
        local success, response = pcall(function()
            return game:HttpGet('https://games.roblox.com/v1/games/' .. PlaceID .. '/servers/Public?sortOrder=Asc&limit=100')
        end)
        
        if success then
            local Site = game.HttpService:JSONDecode(response)
            for _, v in pairs(Site.data) do
                if v.playing < v.maxPlayers and v.id ~= game.JobId then
                    -- Notificação de sucesso
                    StarterGui:SetCore("SendNotification", {
                        Title = "Server Hop",
                        Text = "Servidor encontrado! Teleportando para um local com "..v.playing.." players...",
                        Duration = 5,
                        Icon = "rbxassetid://131153193945220"
                    })
                    
                    task.wait(0.5) -- Pequeno delay para a notificação aparecer
                    game:GetService("TeleportService"):TeleportToPlaceInstance(PlaceID, v.id, vu7)
                    break
                end
            end
        else
            warn("Erro ao buscar servidores.")
        end
    end
})

TabTP:AddButton({
    Name = "Reentrar no Servidor (Rejoin)",
    Callback = function()
