local function applyCollisionLogic(obj)
    if not obj:IsA("BasePart") then return end
    local name = obj.Name:lower()
    local isCar = false
    local parent = obj
    while parent do
        if parent.Name:lower():find(carKeyword) then isCar = true break end
        parent = parent.Parent
    end
    if isCar then obj.CanCollide = not antiCarSit end
end

local function updateSitState()
    local hum = vu7.Character and vu7.Character:FindFirstChildOfClass("Humanoid")
    if hum then
        hum:SetStateEnabled(Enum.HumanoidStateType.Seated, not (antiToolSit or antiCarSit))
        if (antiToolSit or antiCarSit) and hum.Sit then hum.Sit = false end
    end
end
