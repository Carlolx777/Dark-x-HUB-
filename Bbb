local function headsitOnPlayer(targetPlayer)
    if not targetPlayer or not targetPlayer.Character then return end
    local char = vu7.Character
    local root = char:FindFirstChild("HumanoidRootPart")
    local tHead = targetPlayer.Character:FindFirstChild("Head")
    if root and tHead then
        root.CFrame = tHead.CFrame * CFrame.new(0, 2.2, 0)
        local weld = Instance.new("WeldConstraint", root)
        weld.Part0 = root
        weld.Part1 = tHead
        char.Humanoid.Sit = true
    end
end

local function removeHeadsit()
    if vu7.Character and vu7.Character:FindFirstChild("HumanoidRootPart") then
        for _, v in pairs(vu7.Character.HumanoidRootPart:GetChildren()) do
            if v:IsA("WeldConstraint") then v:Destroy() end
        end
        vu7.Character.Humanoid.Sit = false
    end
end

