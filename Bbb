local function SetupBlackHole()
    if not BH_Part then
        BH_Part = Instance.new("Part")
        BH_Part.Name = "BH_TargetPart"
        BH_Part.Anchored = true
        BH_Part.CanCollide = false
        BH_Part.Transparency = 1
        BH_Part.Parent = vu9
        BH_Attachment = Instance.new("Attachment", BH_Part)
    end
end

local function ForcePart(v)
    if v:IsA("BasePart") and not v.Anchored and not v.Parent:FindFirstChildOfClass("Humanoid") and v.Name ~= "Handle" then
        for _, x in ipairs(v:GetChildren()) do
            if x:IsA("BodyMover") or x:IsA("AlignPosition") or x:IsA("Torque") then x:Destroy() end
        end
        v.CanCollide = false
        local torque = Instance.new("Torque", v)
        torque.Torque = Vector3.new(100000000, 1000000000, 100000000)
        local att0 = Instance.new("Attachment", v)
        torque.Attachment0 = att0
        local alignPos = Instance.new("AlignPosition", v)
        alignPos.Name = "BH_Force"
        alignPos.MaxForce = math.huge
        alignPos.MaxVelocity = math.huge
        alignPos.Responsiveness = _G.BH_Strength
        alignPos.Attachment0 = att0
        alignPos.Attachment1 = BH_Attachment
    end
end

