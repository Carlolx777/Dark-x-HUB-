local function fireServer(eventName, args)  
    local ReplicatedStorage = game:GetService("ReplicatedStorage")  
    local event = ReplicatedStorage:FindFirstChild("RE") and ReplicatedStorage.RE:FindFirstChild(eventName)  
    if event then  
        pcall(function()  
