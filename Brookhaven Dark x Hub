Tab5:AddSection({"Dark Avançado"})

local ESPEnabled = false
local espConnections = {}

local function createESP(vehicle)
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "ESP"
    billboard.Adornee = vehicle.PrimaryPart or vehicle
    billboard.Size = UDim2.new(0, 150, 0, 30)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.AlwaysOnTop = true

    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.TextColor3 = Color3.new(0, 1, 0)
    textLabel.TextScaled = true
    textLabel.Font = Enum.Font.SourceSansBold
    textLabel.Parent = billboard

    billboard.Parent = vehicle
    return textLabel
end

local function toggleESP(state)
    ESPEnabled = state
    if not state then
        for _, conn in pairs(espConnections) do conn:Disconnect() end
        espConnections = {}
        for _, v in pairs(workspace.Vehicles:GetChildren()) do
            if v:FindFirstChild("ESP") then v.ESP:Destroy() end
        end
        return
    end

    for _, vehicle in pairs(workspace.Vehicles:GetChildren()) do
        if vehicle:IsA("Model") and not vehicle:FindFirstChild("ESP") then
            local textLabel = createESP(vehicle)
            local conn = game:GetService("RunService").RenderStepped:Connect(function()
                if ESPEnabled and vehicle.PrimaryPart then
                    local plr = game.Players.LocalPlayer
                    local dist = (plr.Character and plr.Character.PrimaryPart.Position - vehicle.PrimaryPart.Position).Magnitude
                    textLabel.Text = vehicle.Name .. " | Dist: " .. math.floor(dist) .. " studs"
                end
            end)
            table.insert(espConnections, conn)
        end
    end
end

