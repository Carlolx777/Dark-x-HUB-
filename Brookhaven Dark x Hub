-- Função para gerar cor rainbow
local function getRainbowColor(speedMultiplier)
    local h = (tick() * speedMultiplier % 5) / 5
    return Color3.fromHSV(h, 1, 1)
end

-- Função para disparar eventos Remotes
local function fireServer(eventName, args)
    local eventFolder = ReplicatedStorage:FindFirstChild("RE")
    if eventFolder and eventFolder:FindFirstChild(eventName) then
        pcall(function()
            eventFolder[eventName]:FireServer(unpack(args))
        end)
    end
end

