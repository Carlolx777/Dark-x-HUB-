local selectedPlayer = nil
local flingLoop = false
local viewLoop = false

local function FlingPlayer()
    task.spawn(function()
        while flingLoop and selectedPlayer do
            local Player = game.Players.LocalPlayer
            local Character = Player.Character
            local RootPart = Character and Character:FindFirstChild("HumanoidRootPart")
            local Vehicles = workspace:FindFirstChild("Vehicles")
            local PCar = Vehicles and Vehicles:FindFirstChild(Player.Name .. "Car")

            if not PCar and RootPart then
                RootPart.CFrame = CFrame.new(RootPart.Position.X, 500, RootPart.Position.Z)
                task.wait(0.5)
                game:GetService("ReplicatedStorage").RE:FindFirstChild("1Ca1r"):FireServer("PickingBoat", "MilitaryBoatFree")
                task.wait(0.8)
                PCar = Vehicles and Vehicles:FindFirstChild(Player.Name .. "Car")
            end

            if PCar and selectedPlayer.Character then
                local targetRoot = selectedPlayer.Character:FindFirstChild("HumanoidRootPart")
                if targetRoot then
                    PCar:SetPrimaryPartCFrame(targetRoot.CFrame * CFrame.new(0, 0, -5))

                    local bv = Instance.new("BodyVelocity")
                    bv.MaxForce = Vector3.new(1e9, 1e9, 1e9)
                    bv.Velocity = Vector3.new(500, 200, 500)
                    bv.Parent = PCar.PrimaryPart

                    local bav = Instance.new("BodyAngularVelocity")
                    bav.MaxTorque = Vector3.new(1e9, 1e9, 1e9)
                    bav.AngularVelocity = Vector3.new(0, 200, 0)
                    bav.Parent = PCar.PrimaryPart

                    task.wait(0.3)
                    bv:Destroy()
                    bav:Destroy()
                end
            end
            task.wait(0.05)
        end
    end)
end

