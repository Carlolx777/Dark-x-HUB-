        ballTool.Parent = character
        
        -- Aguarda a bola física aparecer no servidor/workspace
        local ballName = "Soccer" .. player.Name
        local timeout = 0
        while not ServerBalls:FindFirstChild(ballName) and timeout < 50 do
            timeout = timeout + 1
            task.wait(0.1)
        end
        
        return ServerBalls:FindFirstChild(ballName)
    end

    local Ball = ServerBalls:FindFirstChild("Soccer" .. player.Name) or GetBall()
    if not Ball then return end

    -- Configurações de física da bola para o Fling
    Ball.CanCollide = false
    Ball.Massless = true
    
    local tchar = target.Character
    local troot = tchar:FindFirstChild("HumanoidRootPart")
    local thum = tchar:FindFirstChild("Humanoid")

    if troot and thum then
        -- Remove velocidades antigas
        for _, v in pairs(Ball:GetChildren()) do
            if v:IsA("BodyVelocity") or v:IsA("BodyAngularVelocity") then v:Destroy() end
        end
        
        -- Cria a força do Fling
        local bv = Instance.new("BodyVelocity")
        bv.Name = "FlingPower"
        bv.Velocity = Vector3.new(9e8, 9e8, 9e8)
        bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        bv.P = 9e7
        bv.Parent = Ball
        
        local bav = Instance.new("BodyAngularVelocity")
        bav.AngularVelocity = Vector3.new(9e8, 9e8, 9e8)
        bav.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        bav.P = 9e7
        bav.Parent = Ball

        -- Conexão para seguir o jogador
        flingConnection = RunService.Heartbeat:Connect(function()
            if not running or not tchar or not tchar.Parent or thum.Health <= 0 then
                if flingConnection then flingConnection:Disconnect() end
                if bv then bv:Destroy() end
                if bav then bav:Destroy() end
                return
            end
            
            -- Posiciona a bola no alvo com previsão de movimento
            local pos = troot.Position + (troot.Velocity * 0.1)
            Ball.CFrame = CFrame.new(pos)
        end)
    end
end
