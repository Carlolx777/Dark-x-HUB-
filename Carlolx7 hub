local function GetPlayerNames()
    local names = {}
    for _, p in pairs(game.Players:GetPlayers()) do
        if p ~= player then -- Não incluir a si mesmo
            table.insert(names, p.Name)
        end
    end
    return names
end

local function EquipShoppingCart()
    local ToolName = "Shopping Cart" 
    local ToolNamePT = "Carrinho de compras"
    
    local backpack = player:WaitForChild("Backpack")
    local foundTool = backpack:FindFirstChild(ToolName) or backpack:FindFirstChild(ToolNamePT) or char:FindFirstChild(ToolName) or char:FindFirstChild(ToolNamePT)
    
    if foundTool then
        if foundTool.Parent == backpack then
            foundTool.Parent = char 
        end
        return foundTool
    else
        local anyTool = backpack:FindFirstChildWhichIsA("Tool")
        if anyTool then
            anyTool.Parent = char
            return anyTool
        end
        return nil
    end
end

-- Função específica para equipar a Bola
local function EquipBall()
    local backpack = player:WaitForChild("Backpack")
    -- Nomes comuns da bola no Brookhaven
    local targets = {"Football", "Soccer Ball", "Bola", "Ball"}
    
    local foundTool = nil
    
    -- Verifica se já está equipada
    for _, name in ipairs(targets) do
        if char:FindFirstChild(name) then
            return char:FindFirstChild(name)
        end
    end

    -- Procura na mochila
    for _, name in ipairs(targets) do
        local t = backpack:FindFirstChild(name)
        if t then
            foundTool = t
            break
        end
    end
    
    if foundTool then
        foundTool.Parent = char -- Equipa
        return foundTool
    else
        -- Se não achar pelo nome, tenta pegar o primeiro item (caso o inventário só tenha a bola)
        local anyTool = backpack:FindFirstChildWhichIsA("Tool")
        if anyTool then
            anyTool.Parent = char
            return anyTool
        end
        
        OrionLib:MakeNotification({
            Name = "Aviso",
            Content = "Pegue a BOLA no inventário primeiro!",
            Image = "rbxassetid://4483345998",
            Time = 5
        })
        return nil
    end
end

local function GetTargetRoot()
    if not SelectedPlayerName then return nil end
    local target = game.Players:FindFirstChild(SelectedPlayerName)
    if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
        return target.Character.HumanoidRootPart, target.Character
    end
    return nil
end

