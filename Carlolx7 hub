-- =================================================================
-- NOVA SEÇÃO: FLING BALL
-- =================================================================
PlayerTab:AddSection({Name = "⚽ Fling Ball (Bola Assassina)"})

PlayerTab:AddToggle({
    Name = "Ativar Fling Ball (Girar + Equipar)",
    Default = false,
    Callback = function(Value)
        flingBallEnabled = Value
        
        if flingBallEnabled then
            -- 1. Equipa a ferramenta
            EquipBall()
            
            -- 2. Cria a força de rotação (Girar para todos os lados)
            local BodyAngularVelocity = Instance.new("BodyAngularVelocity")
            BodyAngularVelocity.Name = "FlingSpin"
            BodyAngularVelocity.Parent = root
            BodyAngularVelocity.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
            -- Gira rápido nos eixos X, Y e Z
            BodyAngularVelocity.AngularVelocity = Vector3.new(10000, 10000, 10000)
            
            -- 3. Loop para garantir que a bola fique equipada enquanto gira
            spawn(function()
                while flingBallEnabled and char do
                    if not char:FindFirstChildWhichIsA("Tool") then
                        EquipBall()
                    end
                    -- Pequeno empurrão para frente para ajudar na colisão
                    root.Velocity = root.CFrame.LookVector * 100 
                    wait(0.5)
                end
            end)
            
        else
            -- Desativar
            for _, v in pairs(root:GetChildren()) do
                if v.Name == "FlingSpin" then v:Destroy() end
            end
            root.RotVelocity = Vector3.new(0,0,0)
            root.Velocity = Vector3.new(0,0,0)
        end
    end    
})

-- =================================================================
-- FIM DA NOVA SEÇÃO
-- =================================================================

PlayerTab:AddSection({Name = "Ações com Carrinho (Troll)"})

PlayerTab:AddButton({
    Name = "💀 Kill (Matar)",
    Callback = function()
        local targetRoot = GetTargetRoot()
        if targetRoot then
            local tool = EquipShoppingCart()
            if not tool then return end

            local oldPos = root.CFrame
            noclip = true
            
            -- Lógica de Kill
            local startTime = tick()
            local connection
            connection = RunService.Heartbeat:Connect(function()
                if tick() - startTime > 5 or not targetRoot.Parent then 
                    connection:Disconnect()
                    noclip = false
                    root.CFrame = oldPos
                    root.Velocity = Vector3.new(0,0,0)
                    root.RotVelocity = Vector3.new(0,0,0)
                    return 
                end
                
                root.CFrame = targetRoot.CFrame * CFrame.new(0, 0, 0)
                root.Velocity = Vector3.new(999999, 999999, 999999) 
                root.RotVelocity = Vector3.new(10000, 10000, 10000) 
            end)
        else
            OrionLib:MakeNotification({Name = "Erro", Content = "Selecione um jogador válido!", Time = 3})
        end
    end    
})

PlayerTab:AddButton({
    Name = "🌪️ Fling (Jogar Longe)",
    Callback = function()
        local targetRoot = GetTargetRoot()
        if targetRoot then
            EquipShoppingCart()
            local oldPos = root.CFrame
            noclip = false 
            
            local BodyVelocity = Instance.new("BodyVelocity")
            BodyVelocity.Parent = root
            BodyVelocity.Velocity = Vector3.new(0,0,0)
            BodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)

            local BodyAngularVelocity = Instance.new("BodyAngularVelocity")
            BodyAngularVelocity.Parent = root
            BodyAngularVelocity.AngularVelocity = Vector3.new(0, 99999, 0)
            BodyAngularVelocity.MaxTorque = Vector3.new(0, math.huge, 0)
            
            for i = 1, 50 do 
                root.CFrame = targetRoot.CFrame
                wait(0.05)
            end
            
            BodyVelocity:Destroy()
            BodyAngularVelocity:Destroy()
            noclip = false
            root.Velocity = Vector3.new(0,0,0)
            root.RotVelocity = Vector3.new(0,0,0)
            root.CFrame = oldPos
        end
    end    
})

PlayerTab:AddButton({
    Name = "🧲 Bring (Puxar/Arrastar)",
    Callback = function()
        local targetRoot = GetTargetRoot()
        if targetRoot then
            EquipShoppingCart()
            noclip = true
            
            local startTime = tick()
            local connection
            local bringPos = root.CFrame
            
            connection = RunService.Heartbeat:Connect(function()
                if tick() - startTime > 4 or not targetRoot.Parent then 
                    connection:Disconnect()
                    noclip = false
                    root.Velocity = Vector3.new(0,0,0)
                    return 
                end
                root.CFrame = targetRoot.CFrame * CFrame.new(0,0,1)
                wait(0.05)
                root.CFrame = bringPos
            end)
        end
    end    
})

