                alvoPart.CFrame = eu.Character.HumanoidRootPart.CFrame * CFrame.new(0, -15, 0)
            end
        end)

        -- --- LOGICA DE CAPTURAR PORTAS ---
        local function SetupPorta(part)
            if not part:IsA("BasePart") or part.Anchored or not string.find(part.Name:lower(), "door") then return end
            if part:FindFirstChild("PortaFling_Ativada") then return end
            
            part.CanCollide = false
            local marker = Instance.new("BoolValue", part)
            marker.Name = "PortaFling_Ativada"
            
            local a0 = Instance.new("Attachment", part)
            local align = Instance.new("AlignPosition", part)
            align.Attachment0 = a0
            align.Attachment1 = attTarget
            align.MaxForce = 1e20
            align.MaxVelocity = math.huge
            align.Responsiveness = 200
            
            local torque = Instance.new("Torque", part)
            torque.Attachment0 = a0
            torque.RelativeTo = Enum.ActuatorRelativeTo.World
            torque.Torque = Vector3.new(math.random(-1e7, 1e7), math.random(-1e7, 1e7), math.random(-1e7, 1e7))
        end

