        ferramenta.Unequipped:Connect(function() ferramentaEquipada = false end)
        ferramenta.Parent = mochila

        -- --- DETECÇÃO DE CLIQUE ---
        entrada.InputEnded:Connect(function(input, processed)
            if ferramentaEquipada and (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1) then
